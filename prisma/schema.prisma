generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  company   String?
  country   String?
  email     String
  phone     String?
  commodity String?
  message   String
  userType  String   // Buyer or Supplier
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  userId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
